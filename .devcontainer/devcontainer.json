{
    "name": "STM32 Dev",

    "image": "mcr.microsoft.com/devcontainers/cpp:ubuntu",
    
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "marus25.cortex-debug"
            ]
        }
    },

 
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y git make gcc-arm-none-eabi gdb-multiarch"
}